{
  "name": "dcf-modeling",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/server dev",
    "client:dev": "bun run --cwd packages/client dev",
    "build": "bun run --filter '*' build",
